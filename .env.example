NODE_ENV=development
LOG_LEVEL=debug
# Relative to process cwd. Use ./examples/sample-workspace from the monorepo root.
# Package scripts under servers/workspace-server default to ../../examples/sample-workspace.
MCP_WORKSPACE_ROOT=./examples/sample-workspace
MCP_MAX_FILE_SIZE_BYTES=1048576
MCP_MAX_SEARCH_RESULTS=100
MCP_REPORT_APPROVAL_REQUIRED=true
MCP_TRACE_ENABLED=true
