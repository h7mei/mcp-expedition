{
  "name": "@mcp-expedition/expedition-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "expedition": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-expedition/mcp-client": "workspace:*",
    "@mcp-expedition/protocol-tracer": "workspace:*",
    "@mcp-expedition/shared-config": "workspace:*",
    "@mcp-expedition/shared-schemas": "workspace:*",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
