    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-expedition/protocol-tracer": "workspace:*",
    "@mcp-expedition/shared-schemas": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.15.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
